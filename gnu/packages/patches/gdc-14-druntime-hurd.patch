+module core.sys.hurd.elf;
+
+version (Hurd):
+extern (C):
+pure:
+nothrow:
+@system:
+
+import core.stdc.stdint;
+public import core.sys.elf;
+
+extern (D)
+{
+    auto ELF32_ST_VISIBILITY(O)(O o) { return o & 0x03; }
