+    use std::sync::Arc;
+
+    use codex_code_mode_protocol::{
+        CellId, CodeModeSession, CodeModeSessionDelegate, CodeModeSessionProvider,
+        CodeModeSessionProviderFuture, CodeModeSessionResultFuture, ExecuteRequest, StartedCell,
+        WaitOutcome, WaitRequest,
+    };
+
+    const DISABLED: &str = "code mode is disabled (built without v8-runtime)";
